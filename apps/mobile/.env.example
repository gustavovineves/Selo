# ========================
# Selo Mobile — .env
# ========================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env.
# Ver docs/environments.md para detalhes por ambiente.
#
# Variáveis prefixadas com EXPO_PUBLIC_ são expostas ao bundle do app.
# Nunca coloque segredos em variáveis EXPO_PUBLIC_.

# URL base da API (sem barra final)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# Ambiente (informativo — exibido em banners de teste no app)
# Valores: development | staging | production
EXPO_PUBLIC_APP_ENV=development

# ── Configuração para staging ─────────────────────────────────────
# Copie como apps/mobile/.env.staging — NUNCA commite com valores reais
#
# EXPO_PUBLIC_API_URL=https://api.staging.selo.app/api/v1
# EXPO_PUBLIC_APP_ENV=staging
#
# Após configurar, limpar cache Expo:
#   npx expo start --clear
# ou
#   pnpm --filter @selo/mobile start -- --clear
