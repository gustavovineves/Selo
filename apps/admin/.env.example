# ========================
# Selo Admin — .env
# ========================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o arquivo .env.local.
# Ver docs/environments.md para detalhes por ambiente.

# URL base da API do Selo (sem barra final)
# Deve apontar para o endpoint /api/v1
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Ambiente (informativo — não afeta build Next.js diretamente)
# Valores: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# Versão exibida no rodapé (informativo)
NEXT_PUBLIC_APP_VERSION=1.0.0-beta

# ── Configuração para staging ─────────────────────────────────────
# Copie como apps/admin/.env.local.staging — NUNCA commite com valores reais
#
# NEXT_PUBLIC_API_URL=https://api.staging.selo.app/api/v1
# NEXT_PUBLIC_APP_ENV=staging
# NEXT_PUBLIC_APP_VERSION=1.0.0-beta
