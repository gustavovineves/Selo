# ========================
# Selo API — .env
# Copie este arquivo para .env e preencha com valores reais.
# ========================

# Banco de dados (porta padrão do Docker Compose é 5434 para o Selo)
DATABASE_URL="postgresql://selo:selopassword@localhost:5434/selodb?schema=public"

PORT=3000
NODE_ENV=development

# CORS — origens permitidas (separar por vírgula)
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# JWT — access token (curta duração)
JWT_SECRET=troque-por-uma-string-secreta-de-pelo-menos-64-chars
JWT_EXPIRES_IN=15m

# JWT — refresh token (longa duração, secret diferente)
JWT_REFRESH_SECRET=troque-por-outro-secret-diferente-do-jwt-secret
JWT_REFRESH_EXPIRES_IN=7d

# Pix (Fase 2 — deixar em branco por enquanto)
PIX_BASE_URL=
PIX_CLIENT_ID=
PIX_CLIENT_SECRET=
PIX_CERT_PATH=

# Blockchain (Fase 4 — deixar em branco por enquanto)
BLOCKCHAIN_NETWORK=ethereum-testnet
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_PRIVATE_KEY=
BLOCKCHAIN_CONTRACT_ADDRESS=

# Fitbank / BaaS (Fase 5 — deixar em branco por enquanto)
FITBANK_BASE_URL=
FITBANK_API_KEY=
