# ========================
# Selo API — .env
# ========================
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite o arquivo .env.
# Ver docs/environments.md para detalhes por ambiente.

# ── Banco de dados ────────────────────────────────────────────────
# Porta padrão do Docker Compose do Selo é 5434
DATABASE_URL="postgresql://selo:selopassword@localhost:5434/selodb?schema=public"

# ── App ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=log

# ── JWT — access token ───────────────────────────────────────────
JWT_SECRET=troque-por-uma-string-secreta-de-pelo-menos-64-chars
JWT_EXPIRES_IN=15m

# ── JWT — refresh token (secret diferente do access token) ───────
JWT_REFRESH_SECRET=troque-por-outro-secret-diferente-do-jwt-secret-64-chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Admin JWT (secret separado do JWT de usuário) ─────────────────
# Secret diferente do JWT_SECRET — nunca compartilhar os dois
ADMIN_JWT_SECRET=troque-este-segredo-admin-de-pelo-menos-64-chars-aqui
ADMIN_JWT_EXPIRES_IN=1d

# ── CORS ──────────────────────────────────────────────────────────
# Separar múltiplas origens por vírgula
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# ── Rate limit ────────────────────────────────────────────────────
# TTL em milissegundos (60000 = 60s), MAX = requisições por janela
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# ── URLs públicas ─────────────────────────────────────────────────
APP_PUBLIC_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:3000/api/v1

# ── Admin token estático (legado — não mais recomendado) ──────────
# Mantido por compatibilidade com AdminTokenGuard. Usar AdminJwtGuard.
ADMIN_TOKEN=troque-por-um-token-admin-secreto-de-pelo-menos-32-chars

# ── Futuras integrações (NÃO preencher sem instrução explícita) ───

# Pix / Fitbank BaaS (Fase 24+)
# FUTURE_FITBANK_BASE_URL=
# FUTURE_FITBANK_API_KEY=
# FUTURE_FITBANK_PARTNER_BANK=
# FUTURE_PIX_CLIENT_ID=
# FUTURE_PIX_CLIENT_SECRET=
# FUTURE_PIX_CERT_PATH=

# Blockchain (Fase 26+)
# FUTURE_BLOCKCHAIN_NETWORK=ethereum-testnet
# FUTURE_BLOCKCHAIN_RPC_URL=
# FUTURE_BLOCKCHAIN_PRIVATE_KEY=
# FUTURE_BLOCKCHAIN_CONTRACT_ADDRESS=
