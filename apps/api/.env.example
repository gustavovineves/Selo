# ========================
# Selo API — .env
# ========================

DATABASE_URL="postgresql://selo:selopassword@localhost:5432/selodb?schema=public"

PORT=3000
NODE_ENV=development

JWT_SECRET=troque-por-uma-string-secreta-de-pelo-menos-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-por-outro-secret-diferente-do-jwt-secret
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# Pix (Fase 2)
PIX_BASE_URL=
PIX_CLIENT_ID=
PIX_CLIENT_SECRET=
PIX_CERT_PATH=

# Blockchain (Fase 4)
BLOCKCHAIN_NETWORK=ethereum-testnet
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_PRIVATE_KEY=
BLOCKCHAIN_CONTRACT_ADDRESS=

# Fitbank / BaaS (Fase 5)
FITBANK_BASE_URL=
FITBANK_API_KEY=
