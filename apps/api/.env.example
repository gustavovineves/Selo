# ========================
# Selo API — .env
# ========================
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite o arquivo .env.
# Ver docs/environments.md para detalhes por ambiente.

# ── Banco de dados ────────────────────────────────────────────────
# Porta padrão do Docker Compose do Selo é 5434
DATABASE_URL="postgresql://selo:selopassword@localhost:5434/selodb?schema=public"

# ── App ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=log

# ── JWT — access token ───────────────────────────────────────────
JWT_SECRET=troque-por-uma-string-secreta-de-pelo-menos-64-chars
JWT_EXPIRES_IN=15m

# ── JWT — refresh token (secret diferente do access token) ───────
JWT_REFRESH_SECRET=troque-por-outro-secret-diferente-do-jwt-secret-64-chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Admin JWT (secret separado do JWT de usuário) ─────────────────
# Secret diferente do JWT_SECRET — nunca compartilhar os dois
ADMIN_JWT_SECRET=troque-este-segredo-admin-de-pelo-menos-64-chars-aqui
ADMIN_JWT_EXPIRES_IN=1d

# ── CORS ──────────────────────────────────────────────────────────
# Separar múltiplas origens por vírgula
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# ── Rate limit ────────────────────────────────────────────────────
# TTL em milissegundos (60000 = 60s), MAX = requisições por janela
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# ── URLs públicas ─────────────────────────────────────────────────
APP_PUBLIC_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:3000/api/v1

# ── Admin token estático (legado — não mais recomendado) ──────────
# Mantido por compatibilidade com AdminTokenGuard. Usar AdminJwtGuard.
ADMIN_TOKEN=troque-por-um-token-admin-secreto-de-pelo-menos-32-chars

# ── Pagamento — provider de pagamento ────────────────────────────
# simulated  → comportamento simulado local (padrão)
# fitbank_sandbox → sandbox Fitbank sem chamada real (requer FITBANK_ENABLE_REAL_CALLS=false)
PAYMENT_PROVIDER=simulated

# ── Fitbank Sandbox (Fase 24 — não usar valores reais) ────────────
# Ambiente Fitbank: sandbox | production
FITBANK_ENV=sandbox

# Habilitar chamadas reais ao Fitbank. MANTER false em sandbox/dev/test.
FITBANK_ENABLE_REAL_CALLS=false

# Preencher apenas quando disponível o ambiente de sandbox do Fitbank:
# FITBANK_API_BASE_URL=https://sandbox.fitbank.com.br
# FITBANK_CLIENT_ID=
# FITBANK_CLIENT_SECRET=
# FITBANK_WEBHOOK_SECRET=
# FITBANK_PIX_KEY=

# ── KYC / Verificação Financeira (Fase 25) ───────────────────────
# Provedor de KYC: simulated (padrão)
KYC_PROVIDER=simulated

# Habilitar chamadas reais ao provedor de KYC. NUNCA true sem instrução explícita.
KYC_ENABLE_REAL_CALLS=false

# Permitir endpoints de simulação (simulate-approval/rejection).
# DEVE ser false em production.
# Não é necessário declarar — é inferido de NODE_ENV automaticamente.
# KYC_SIMULATION_ALLOWED=true  # em development/test
# KYC_SIMULATION_ALLOWED=false # em production (padrão)

# Chaves de API do provedor real de KYC (Fase futura):
# FUTURE_KYC_PROVIDER_API_KEY=
# FUTURE_KYC_PROVIDER_BASE_URL=

# ── Blockchain (Fase 26+) ─────────────────────────────────────────
# FUTURE_BLOCKCHAIN_NETWORK=ethereum-testnet
# FUTURE_BLOCKCHAIN_RPC_URL=
# FUTURE_BLOCKCHAIN_PRIVATE_KEY=
# FUTURE_BLOCKCHAIN_CONTRACT_ADDRESS=
