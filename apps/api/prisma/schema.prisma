// =============================================================
// Selo — Prisma Schema
// Fonte da verdade para o banco de dados.
// Não rodar migrations sem coordenação da equipe.
// Atualizar este arquivo → pnpm db:migrate
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// ENUMS — Usuários e Identidade
// =============================================================

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  DELETED
}

enum KycStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum DocumentType {
  CPF
  CNPJ
  PASSPORT
  OTHER
}

// Tipo de ator em eventos, histórico de status e resoluções.
// Utilizado em AgreementStatusHistory, AgreementEvent e Dispute.
enum ActorType {
  USER
  ADMIN
  SYSTEM
}

// =============================================================
// ENUMS — Chaves e Destinos de Recebimento
// =============================================================

enum ReceivingKeyType {
  CPF
  CNPJ
  EMAIL
  PHONE
  RANDOM
}

enum ReceivingKeyStatus {
  ACTIVE
  PENDING_VALIDATION
  QUARANTINED
  DELETED
}

enum ReceivingDestinationType {
  PIX_CPF
  PIX_CNPJ
  PIX_EMAIL
  PIX_PHONE
  PIX_RANDOM
}

enum ReceivingDestinationStatus {
  ACTIVE
  DELETED
}

// =============================================================
// ENUMS — Acordos
// =============================================================

enum AgreementType {
  SIMPLE
  WITH_GUARANTEE
}

enum AgreementMode {
  STANDARD
  REAL_TIME
}

enum AgreementOperationalStatus {
  DRAFT
  AWAITING_ACCEPTANCE
  ACTIVE
  AWAITING_CONFIRMATION
  COMPLETED
  CANCELLED
  EXPIRED
}

enum AgreementFinancialStatus {
  NONE
  AWAITING_PAYMENT
  FUNDS_HELD
  AWAITING_PAYOUT
  PAID_OUT
  AWAITING_REFUND
  REFUNDED
  DISPUTED
}

enum AgreementParticipantRole {
  CREATOR
  COUNTERPART
  WITNESS
  MEDIATOR
}

enum AgreementParticipantStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum AgreementEventType {
  CREATED
  SENT
  ACCEPTANCE_REQUESTED
  ACCEPTED
  REJECTED
  ACTIVATED
  PAYMENT_REQUESTED
  PAYMENT_RECEIVED
  FUNDS_LOCKED
  CONFIRMATION_REQUESTED
  CONFIRMED
  COMPLETED
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  CANCELLED
  EXPIRED
  BLOCKCHAIN_SUBMITTED
  BLOCKCHAIN_CONFIRMED
  PAYOUT_INITIATED
  PAYOUT_COMPLETED
  REFUND_INITIATED
  REFUND_COMPLETED
}

enum ConfirmationRule {
  MANUAL
  SINGLE_PARTY
  AUTO_ON_DUE_DATE
}

enum ReleaseRule {
  MANUAL
  AUTO_ON_CONFIRMATION
  AUTO_ON_DUE_DATE
}

enum RefundRule {
  MANUAL
  AUTO_ON_DISPUTE_WIN
  AUTO_ON_EXPIRY
}

enum DisputeRule {
  ALLOWED
  NOT_ALLOWED
}

// =============================================================
// ENUMS — Financeiro
// =============================================================

enum FinancialGuaranteeStatus {
  AWAITING_PAYMENT
  LOCKED
  AWAITING_PAYOUT
  PAID_OUT
  AWAITING_REFUND
  REFUNDED
  FROZEN_DISPUTE
}

enum PaymentProvider {
  PIX
  FITBANK
}

enum PaymentMethod {
  PIX
  BANK_TRANSFER
}

enum PaymentIntentStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  FAILED
  CANCELLED
  EXPIRED
}

enum PixChargeStatus {
  PENDING
  ACTIVE
  COMPLETED
  EXPIRED
  FAILED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum RefundStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// =============================================================
// ENUMS — Disputas
// =============================================================

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  AWAITING_EVIDENCE
  RESOLVED_FAVOR_CREATOR
  RESOLVED_FAVOR_COUNTERPART
  WITHDRAWN
  CLOSED
}

enum DisputeMessageType {
  TEXT
  EVIDENCE
  SYSTEM_NOTE
  ADMIN_NOTE
  RESOLUTION
}

// =============================================================
// ENUMS — Score de Confiança
// =============================================================

enum TrustScoreLevel {
  VERY_LOW
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum TrustScoreEventType {
  INITIAL_SCORE
  AGREEMENT_COMPLETED
  AGREEMENT_CANCELLED_BY_USER
  DISPUTE_OPENED
  DISPUTE_WON
  DISPUTE_LOST
  KYC_VERIFIED
  MANUAL_ADJUSTMENT
}

// =============================================================
// ENUMS — Blockchain
// =============================================================

enum BlockchainNetwork {
  ETHEREUM_TESTNET
  POLYGON_TESTNET
  ETHEREUM_MAINNET
  POLYGON_MAINNET
}

enum BlockchainRecordStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
}

// =============================================================
// ENUMS — Notificações e Auditoria
// =============================================================

enum NotificationType {
  AGREEMENT_RECEIVED
  AGREEMENT_ACCEPTED
  AGREEMENT_REJECTED
  AGREEMENT_COMPLETED
  AGREEMENT_CANCELLED
  AGREEMENT_EXPIRED
  PAYMENT_RECEIVED
  FUNDS_LOCKED
  PAYOUT_SENT
  REFUND_PROCESSED
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  TRUST_SCORE_UPDATED
  SYSTEM_ALERT
}

enum NotificationStatus {
  UNREAD
  READ
  DISMISSED
}

enum AuditAction {
  USER_CREATED
  USER_UPDATED
  USER_SUSPENDED
  USER_DELETED
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGED
  AGREEMENT_CREATED
  AGREEMENT_SENT
  AGREEMENT_ACCEPTED
  AGREEMENT_REJECTED
  AGREEMENT_COMPLETED
  AGREEMENT_CANCELLED
  AGREEMENT_DISPUTED
  PAYMENT_INITIATED
  PAYMENT_COMPLETED
  PAYMENT_FAILED
  PAYOUT_INITIATED
  PAYOUT_COMPLETED
  REFUND_INITIATED
  REFUND_COMPLETED
  ADMIN_ACTION
  ADMIN_DISPUTE_RESOLVED
  ADMIN_USER_SUSPENDED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
  READ_ONLY
}

enum AdminStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

// =============================================================
// MODEL: User
// =============================================================

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  phone           String?       @unique
  document        String?       @unique // CPF/CNPJ/Passaporte — apenas dígitos ou código
  documentType    DocumentType?
  passwordHash    String
  status          UserStatus    @default(ACTIVE)
  kycStatus       KycStatus     @default(PENDING)
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  profile                 UserProfile?
  sessions                DeviceSession[]
  receivingKeys           ReceivingKey[]
  receivingDestinations   ReceivingDestination[]
  createdAgreements       Agreement[]            @relation("AgreementCreator")
  payerAgreements         Agreement[]            @relation("AgreementPayer")
  receiverAgreements      Agreement[]            @relation("AgreementReceiver")
  agreementParticipations AgreementParticipant[]
  paymentIntents          PaymentIntent[]
  receivedPayouts         Payout[]               @relation("PayoutRecipient")
  requestedRefunds        Refund[]               @relation("RefundRequester")
  receivedRefunds         Refund[]               @relation("RefundRecipient")
  openedDisputes          Dispute[]
  trustScore              TrustScore?
  trustScoreEvents        TrustScoreEvent[]
  notifications           Notification[]
  auditLogs               AuditLog[]

  @@index([email])
  @@index([document])
  @@index([status])
  @@map("users")
}

// =============================================================
// MODEL: UserProfile
// =============================================================

model UserProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  fullName    String
  displayName String?
  avatarUrl   String?
  bio         String?
  city        String?
  state       String?
  country     String?   @default("BR")
  birthDate   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// =============================================================
// MODEL: DeviceSession
// Cada sessão autenticada de um dispositivo.
// Suporta logout por dispositivo e múltiplos refresh tokens
// sem invalidar outros aparelhos.
// =============================================================

model DeviceSession {
  id           String    @id @default(cuid())
  userId       String
  refreshToken String    @unique
  deviceName   String?
  deviceOs     String?
  ip           String?
  userAgent    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, expiresAt]) // sessões ativas de um usuário
  @@map("device_sessions")
}

// =============================================================
// MODEL: ReceivingKey
// Chave Pix registrada pelo usuário para receber pagamentos.
// normalizedKey é globalmente único — chaves excluídas não
// podem ser reutilizadas por outro usuário no MVP.
// IMPORTANTE: unicidade de isDefault = true por usuário deve
// ser enforçada na camada de serviço (Prisma não suporta
// partial unique index).
// =============================================================

model ReceivingKey {
  id               String             @id @default(cuid())
  userId           String
  type             ReceivingKeyType
  key              String // chave no formato original exibido ao usuário
  normalizedKey    String             @unique // normalizada: lowercase / só dígitos
  status           ReceivingKeyStatus @default(ACTIVE)
  isDefault        Boolean            @default(false)
  quarantinedUntil DateTime? // bloqueada para evitar fraude pós-exclusão
  deletedAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pixCharges PixCharge[]
  payouts    Payout[] // payouts que usaram esta chave como destino

  @@index([userId, status])
  @@index([normalizedKey])
  @@map("receiving_keys")
}

// =============================================================
// MODEL: ReceivingDestination
// Destino de pagamento salvo pelo usuário (favoritos para
// enviar dinheiro a outros). Separado de ReceivingKey, que
// são as próprias chaves do usuário para receber.
// IMPORTANTE: unicidade de isDefault = true por usuário deve
// ser enforçada na camada de serviço.
// =============================================================

model ReceivingDestination {
  id        String                     @id @default(cuid())
  userId    String
  nickname  String
  type      ReceivingDestinationType
  keyValue  String
  status    ReceivingDestinationStatus @default(ACTIVE)
  bankName  String?
  bankIspb  String? // código ISPB do banco destino
  isDefault Boolean                    @default(false)
  metadata  Json?
  deletedAt DateTime?
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payouts Payout[] // payouts que usaram este destino salvo

  @@index([userId, status])
  @@map("receiving_destinations")
}

// =============================================================
// MODEL: Agreement
// Núcleo do produto. Suporta acordos simples e com garantia.
// Dois eixos de status independentes:
//   operationalStatus — ciclo de vida do acordo
//   financialStatus   — estado do dinheiro associado
//
// contentHash: SHA256 local dos termos do acordo, calculado
// pelo backend no momento da criação.
// Diferente de BlockchainRecord.proofHash, que é o hash
// registrado/enviado à blockchain na Fase 4.
// =============================================================

model Agreement {
  id                          String                     @id @default(cuid())
  type                        AgreementType
  mode                        AgreementMode              @default(STANDARD)
  operationalStatus           AgreementOperationalStatus @default(DRAFT)
  financialStatus             AgreementFinancialStatus   @default(NONE)
  title                       String
  generatedSummary            String? // resumo gerado pelo sistema
  description                 String?
  amount                      Decimal?                   @db.Decimal(18, 2)
  currency                    String                     @default("BRL")
  dueDate                     DateTime?
  acceptanceExpiresAt         DateTime? // prazo para contraparte aceitar
  confirmationDeadlineAt      DateTime? // prazo para confirmação de conclusão
  createdById                 String
  payerId                     String? // quem paga a garantia (WITH_GUARANTEE)
  receiverId                  String? // quem recebe o payout (WITH_GUARANTEE)
  receiverKeySnapshot         Json? // snapshot da chave do recebedor no momento da criação
  receiverDestinationSnapshot Json? // snapshot do destino do recebedor no momento da criação
  confirmationRule            ConfirmationRule           @default(MANUAL)
  releaseRule                 ReleaseRule                @default(MANUAL)
  refundRule                  RefundRule                 @default(MANUAL)
  disputeRule                 DisputeRule                @default(ALLOWED)
  contentHash                 String? // SHA256 local dos termos; ver BlockchainRecord.proofHash
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt
  completedAt                 DateTime?
  canceledAt                  DateTime?
  disputedAt                  DateTime?

  createdBy          User                     @relation("AgreementCreator", fields: [createdById], references: [id])
  payer              User?                    @relation("AgreementPayer", fields: [payerId], references: [id])
  receiver           User?                    @relation("AgreementReceiver", fields: [receiverId], references: [id])
  participants       AgreementParticipant[]
  events             AgreementEvent[]
  statusHistory      AgreementStatusHistory[]
  financialGuarantee FinancialGuarantee?
  paymentIntents     PaymentIntent[]
  payouts            Payout[]
  refunds            Refund[]
  dispute            Dispute?
  blockchainRecord   BlockchainRecord?

  @@index([createdById])
  @@index([payerId])
  @@index([receiverId])
  @@index([operationalStatus])
  @@index([financialStatus])
  @@index([createdAt])
  @@map("agreements")
}

// =============================================================
// MODEL: AgreementParticipant
// Participantes formais de um acordo com seus papéis e status.
//
// Unicidade:
// - @@unique([agreementId, userId]): um usuário registrado
//   não pode ser participante duas vezes no mesmo acordo.
// - @@unique([agreementId, email]): um email não registrado
//   não pode ser convidado duas vezes no mesmo acordo.
// - Validação adicional de duplicidade (userId null + email null)
//   deve ser enforçada na camada de serviço.
// =============================================================

model AgreementParticipant {
  id          String                     @id @default(cuid())
  agreementId String
  userId      String?
  email       String? // para participantes sem conta no Selo
  role        AgreementParticipantRole
  status      AgreementParticipantStatus @default(PENDING)
  acceptedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  agreement Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@unique([agreementId, userId])
  @@unique([agreementId, email])
  @@index([agreementId, role]) // buscar criador ou contraparte de um acordo
  @@index([userId])
  @@index([email]) // lookup de convites por email
  @@map("agreement_participants")
}

// =============================================================
// MODEL: AgreementEvent
// Linha do tempo imutável de cada acordo.
// actorType identifica se a ação foi de usuário, admin ou sistema.
// =============================================================

model AgreementEvent {
  id          String             @id @default(cuid())
  agreementId String
  actorId     String?
  actorType   ActorType?
  type        AgreementEventType
  payload     Json?
  note        String?
  createdAt   DateTime           @default(now())

  agreement Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@index([agreementId])
  @@index([type])
  @@map("agreement_events")
}

// =============================================================
// MODEL: AgreementStatusHistory
// Histórico auditável de cada mudança de status operacional
// e/ou financeiro. actorType identifica quem causou a mudança.
// =============================================================

model AgreementStatusHistory {
  id                  String                      @id @default(cuid())
  agreementId         String
  actorId             String?
  actorType           ActorType?
  previousOperational AgreementOperationalStatus?
  newOperational      AgreementOperationalStatus?
  previousFinancial   AgreementFinancialStatus?
  newFinancial        AgreementFinancialStatus?
  reason              String?
  createdAt           DateTime                    @default(now())

  agreement Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@index([agreementId])
  @@map("agreement_status_history")
}

// =============================================================
// MODEL: FinancialGuarantee
// Existe apenas para acordos WITH_GUARANTEE.
// Representa o dinheiro travado no período do acordo.
//
// Relações 1:N com PaymentIntent, Payout e Refund:
// Uma garantia pode ter múltiplas tentativas de pagamento,
// payout ou refund ao longo do tempo (retry flow).
// O estado ativo de cada operação é controlado por status +
// idempotencyKey na camada de serviço.
// =============================================================

model FinancialGuarantee {
  id          String                   @id @default(cuid())
  agreementId String                   @unique
  amount      Decimal                  @db.Decimal(18, 2)
  currency    String                   @default("BRL")
  status      FinancialGuaranteeStatus @default(AWAITING_PAYMENT)
  lockedAt    DateTime?
  releasedAt  DateTime?
  revertedAt  DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  agreement      Agreement       @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  paymentIntents PaymentIntent[] @relation("GuaranteePaymentIntent") // múltiplas tentativas possíveis
  payouts        Payout[]        @relation("GuaranteePayout") // múltiplas tentativas possíveis
  refunds        Refund[]        @relation("GuaranteeRefund") // múltiplas tentativas possíveis

  @@map("financial_guarantees")
}

// =============================================================
// MODEL: PaymentIntent
// Intenção de pagamento. Representa um pedido de cobrança.
// idempotencyKey garante que a mesma operação não seja
// executada duas vezes em caso de retry.
//
// financialGuaranteeId NÃO é @unique: uma garantia pode ter
// múltiplos PaymentIntents (tentativas). Apenas um deve estar
// em estado não-terminal por vez — enforçado pelo serviço.
// =============================================================

model PaymentIntent {
  id                   String              @id @default(cuid())
  agreementId          String?
  financialGuaranteeId String? // sem @unique — permite retry
  payerId              String
  amount               Decimal             @db.Decimal(18, 2)
  currency             String              @default("BRL")
  provider             PaymentProvider     @default(PIX)
  method               PaymentMethod       @default(PIX)
  status               PaymentIntentStatus @default(PENDING)
  idempotencyKey       String              @unique
  externalId           String?
  metadata             Json?
  paidAt               DateTime?
  failedAt             DateTime?
  canceledAt           DateTime?
  expiresAt            DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  agreement          Agreement?          @relation(fields: [agreementId], references: [id])
  financialGuarantee FinancialGuarantee? @relation("GuaranteePaymentIntent", fields: [financialGuaranteeId], references: [id])
  payer              User                @relation(fields: [payerId], references: [id])
  pixCharge          PixCharge?
  refunds            Refund[]

  @@index([agreementId])
  @@index([payerId])
  @@index([payerId, status]) // query mais comum: pagamentos de um usuário por status
  @@index([status])
  @@index([financialGuaranteeId])
  @@map("payment_intents")
}

// =============================================================
// MODEL: PixCharge
// Cobrança Pix gerada para um PaymentIntent.
// Contém QR Code, txid do PSP e dados da liquidação.
// =============================================================

model PixCharge {
  id              String           @id @default(cuid())
  paymentIntentId String           @unique
  receivingKeyId  String? // chave usada; nullable pois a chave pode ser excluída depois
  txid            String?          @unique // ID da cobrança no PSP
  endToEndId      String?          @unique // E2eId da liquidação Pix
  pixKey          String // valor da chave no momento da cobrança
  pixKeyType      ReceivingKeyType
  qrCode          String? // copia-e-cola EMV
  qrCodeBase64    String? // imagem do QR Code em base64
  amount          Decimal          @db.Decimal(18, 2)
  status          PixChargeStatus  @default(PENDING)
  expiresAt       DateTime?
  paidAt          DateTime?
  rawRequest      Json? // payload enviado ao PSP
  rawResponse     Json? // resposta bruta do PSP
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  paymentIntent PaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)
  receivingKey  ReceivingKey? @relation(fields: [receivingKeyId], references: [id])

  @@index([txid])
  @@map("pix_charges")
}

// =============================================================
// MODEL: Payout
// Liberação de dinheiro para o recebedor após conclusão do acordo.
// idempotencyKey garante execução única em caso de retry.
//
// financialGuaranteeId NÃO é @unique — permite retry.
//
// Semântica de destino:
// - recipientKeyId: FK para a ReceivingKey do recebedor registrada
//   no Selo (quando disponível).
// - recipientDestinationId: FK para ReceivingDestination salva
//   pelo usuário (quando o recebedor está como favorito).
// - destinationSnapshot: snapshot do destino exato no momento
//   do payout (sempre preenchido, independente dos FKs).
// =============================================================

model Payout {
  id                     String          @id @default(cuid())
  agreementId            String
  financialGuaranteeId   String? // sem @unique — permite retry
  recipientId            String
  recipientKeyId         String? // ReceivingKey do recebedor no Selo
  recipientDestinationId String? // ReceivingDestination usado como favorito
  destinationSnapshot    Json? // snapshot do destino exato no momento do payout
  amount                 Decimal         @db.Decimal(18, 2)
  currency               String          @default("BRL")
  provider               PaymentProvider @default(PIX)
  status                 PayoutStatus    @default(PENDING)
  idempotencyKey         String          @unique
  externalId             String?
  metadata               Json?
  initiatedAt            DateTime?
  completedAt            DateTime?
  failedAt               DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  agreement            Agreement             @relation(fields: [agreementId], references: [id])
  financialGuarantee   FinancialGuarantee?   @relation("GuaranteePayout", fields: [financialGuaranteeId], references: [id])
  recipient            User                  @relation("PayoutRecipient", fields: [recipientId], references: [id])
  recipientKey         ReceivingKey?         @relation(fields: [recipientKeyId], references: [id])
  recipientDestination ReceivingDestination? @relation(fields: [recipientDestinationId], references: [id])

  @@index([agreementId])
  @@index([agreementId, status]) // verificar payout completo para um acordo
  @@index([recipientId])
  @@index([status])
  @@index([financialGuaranteeId])
  @@map("payouts")
}

// =============================================================
// MODEL: Refund
// Devolução de dinheiro ao pagador.
// Pode ser originada de disputa, expiração ou cancelamento.
//
// financialGuaranteeId NÃO é @unique — permite retry.
// =============================================================

model Refund {
  id                   String       @id @default(cuid())
  paymentIntentId      String
  agreementId          String?
  financialGuaranteeId String? // sem @unique — permite retry
  requestedById        String
  recipientId          String // quem recebe o reembolso (geralmente o pagador)
  amount               Decimal      @db.Decimal(18, 2)
  currency             String       @default("BRL")
  reason               String?
  status               RefundStatus @default(PENDING)
  idempotencyKey       String       @unique
  externalId           String?
  metadata             Json?
  processedAt          DateTime?
  failedAt             DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  paymentIntent      PaymentIntent       @relation(fields: [paymentIntentId], references: [id])
  agreement          Agreement?          @relation(fields: [agreementId], references: [id])
  financialGuarantee FinancialGuarantee? @relation("GuaranteeRefund", fields: [financialGuaranteeId], references: [id])
  requestedBy        User                @relation("RefundRequester", fields: [requestedById], references: [id])
  recipient          User                @relation("RefundRecipient", fields: [recipientId], references: [id])

  @@index([paymentIntentId])
  @@index([agreementId])
  @@index([status])
  @@index([financialGuaranteeId])
  @@map("refunds")
}

// =============================================================
// MODEL: Dispute
// Trava o acordo e abre processo de mediação.
// resolvedByType identifica se quem resolveu foi um User,
// um AdminUser ou o próprio Sistema.
// =============================================================

model Dispute {
  id             String        @id @default(cuid())
  agreementId    String        @unique
  openedById     String
  reason         String
  description    String
  status         DisputeStatus @default(OPEN)
  resolution     String?
  resolvedById   String? // ID do User ou AdminUser que resolveu
  resolvedByType ActorType? // desambigua: USER | ADMIN | SYSTEM
  resolvedAt     DateTime?
  closedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  agreement Agreement        @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  openedBy  User             @relation(fields: [openedById], references: [id])
  messages  DisputeMessage[]

  @@index([status])
  @@map("disputes")
}

// =============================================================
// MODEL: DisputeMessage
// Mensagens trocadas durante a mediação de uma disputa.
// =============================================================

model DisputeMessage {
  id          String             @id @default(cuid())
  disputeId   String
  senderId    String?
  senderType  String // "USER" | "ADMIN" | "SYSTEM"
  type        DisputeMessageType @default(TEXT)
  content     String
  attachments Json? // lista de URLs/metadados de anexos
  createdAt   DateTime           @default(now())

  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@map("dispute_messages")
}

// =============================================================
// MODEL: TrustScore
// Score de confiança agregado por usuário.
// Recalculado via TrustScoreService após eventos relevantes.
// Range: 0–1000. Default: 500.
// =============================================================

model TrustScore {
  id                  String          @id @default(cuid())
  userId              String          @unique
  score               Int             @default(500)
  level               TrustScoreLevel @default(MEDIUM)
  totalAgreements     Int             @default(0)
  completedAgreements Int             @default(0)
  canceledAgreements  Int             @default(0)
  disputesOpened      Int             @default(0)
  disputesWon         Int             @default(0)
  disputesLost        Int             @default(0)
  lastCalculatedAt    DateTime        @default(now())
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  events TrustScoreEvent[]

  @@map("trust_scores")
}

// =============================================================
// MODEL: TrustScoreEvent
// Registro imutável de cada variação no score.
// Permite auditar e recalcular o histórico completo.
// =============================================================

model TrustScoreEvent {
  id            String              @id @default(cuid())
  userId        String
  trustScoreId  String
  type          TrustScoreEventType
  scoreBefore   Int
  scoreDelta    Int // positivo = aumento; negativo = queda
  scoreAfter    Int
  reason        String?
  referenceId   String? // ID do acordo, disputa, etc.
  referenceType String? // "Agreement" | "Dispute" | "Manual"
  createdAt     DateTime            @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  trustScore TrustScore @relation(fields: [trustScoreId], references: [id])

  @@index([userId])
  @@index([trustScoreId])
  @@index([userId, type]) // buscar eventos de um tipo específico por usuário
  @@index([createdAt])
  @@map("trust_score_events")
}

// =============================================================
// MODEL: BlockchainRecord
// Stub para Fase 4. Armazena o hash SHA256 dos termos do acordo
// e o hash da transação na blockchain após confirmação.
//
// proofHash: hash enviado/registrado na blockchain.
// Diferente de Agreement.contentHash, que é o hash local
// dos termos calculado antes de qualquer submissão à chain.
// =============================================================

model BlockchainRecord {
  id              String                 @id @default(cuid())
  agreementId     String                 @unique
  network         BlockchainNetwork      @default(ETHEREUM_TESTNET)
  txHash          String?
  blockNumber     BigInt?
  contractAddress String?
  proofHash       String? // hash registrado na blockchain
  proofData       Json? // dados que geraram o proofHash
  status          BlockchainRecordStatus @default(PENDING)
  retryCount      Int                    @default(0)
  confirmedAt     DateTime?
  failedAt        DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  agreement Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@index([txHash])
  @@map("blockchain_records")
}

// =============================================================
// MODEL: Notification
// Notificações internas e push para o app mobile.
// data: JSON com deep link e metadados do evento.
// =============================================================

model Notification {
  id        String             @id @default(cuid())
  userId    String
  type      NotificationType
  status    NotificationStatus @default(UNREAD)
  title     String
  body      String
  data      Json? // extras para deep link no app
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
  @@map("notifications")
}

// =============================================================
// MODEL: AuditLog
// Registro auditável de ações críticas.
// adminUserId é String (sem FK explícita) para desacoplar do
// ciclo de vida de AdminUser e evitar cascade acidental.
// =============================================================

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  adminUserId String? // ID do AdminUser quando a ação vem do painel
  action      AuditAction
  resource    String
  resourceId  String?
  oldData     Json?
  newData     Json?
  ip          String?
  userAgent   String?
  requestId   String? // correlation ID da requisição HTTP
  createdAt   DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([adminUserId])
  @@index([resource, resourceId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================
// MODEL: AdminUser
// Usuários do painel administrativo (Fase 4).
// Autenticação separada dos usuários do app.
// =============================================================

model AdminUser {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String
  passwordHash String
  role         AdminRole   @default(SUPPORT)
  status       AdminStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  @@index([email])
  @@map("admin_users")
}
