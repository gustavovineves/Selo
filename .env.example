# ============================
# Selo — Variáveis de Ambiente
# ============================
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env.

# Banco de dados PostgreSQL
POSTGRES_USER=selo
POSTGRES_PASSWORD=selopassword
POSTGRES_DB=selodb
POSTGRES_PORT=5432

# String de conexão Prisma (gerada a partir das variáveis acima)
DATABASE_URL="postgresql://selo:selopassword@localhost:5432/selodb?schema=public"

# JWT
JWT_SECRET=troque-por-uma-string-secreta-de-pelo-menos-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-por-outro-secret-diferente-do-jwt-secret
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=3000
NODE_ENV=development

# CORS (separar múltiplas origens por vírgula)
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# Pix (Fase 2 — preencher quando integrar BaaS)
PIX_BASE_URL=
PIX_CLIENT_ID=
PIX_CLIENT_SECRET=
PIX_CERT_PATH=

# Blockchain (Fase 4 — preencher quando integrar)
BLOCKCHAIN_NETWORK=ethereum-testnet
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_PRIVATE_KEY=
BLOCKCHAIN_CONTRACT_ADDRESS=

# Fitbank / BaaS (Fase 5 — preencher quando integrar)
FITBANK_BASE_URL=
FITBANK_API_KEY=
FITBANK_PARTNER_BANK=
