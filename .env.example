# ============================
# Selo — Variáveis de Ambiente (raiz)
# ============================
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env.
# Ver docs/environments.md para detalhes por ambiente.

# ── Banco de dados PostgreSQL (Docker Compose) ────────────────────
POSTGRES_USER=selo
POSTGRES_PASSWORD=selopassword
POSTGRES_DB=selodb
POSTGRES_PORT=5434

# String de conexão Prisma (gerada a partir das variáveis acima)
DATABASE_URL="postgresql://selo:selopassword@localhost:5434/selodb?schema=public"

# ── App ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=log

# ── JWT — access token (curta duração) ───────────────────────────
JWT_SECRET=troque-por-uma-string-secreta-de-pelo-menos-64-chars
JWT_EXPIRES_IN=15m

# ── JWT — refresh token (longa duração, secret diferente) ────────
JWT_REFRESH_SECRET=troque-por-outro-secret-diferente-do-jwt-secret-64-chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Admin JWT (secret separado do JWT de usuário) ─────────────────
ADMIN_JWT_SECRET=troque-este-segredo-admin-de-pelo-menos-64-chars-aqui
ADMIN_JWT_EXPIRES_IN=1d

# ── CORS (separar múltiplas origens por vírgula) ──────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# ── Rate limit ────────────────────────────────────────────────────
# TTL em milissegundos (60000 = 60s), MAX = requisições por janela
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# ── URLs públicas ─────────────────────────────────────────────────
APP_PUBLIC_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:3000/api/v1

# ── Pagamento — provider ──────────────────────────────────────────
# simulated         → comportamento simulado local (padrão)
# fitbank_sandbox   → sandbox Fitbank sem chamada real
PAYMENT_PROVIDER=simulated

# ── Fitbank Sandbox (Fase 24 — não usar valores reais) ────────────
FITBANK_ENV=sandbox
FITBANK_ENABLE_REAL_CALLS=false
# FITBANK_API_BASE_URL=https://sandbox.fitbank.com.br
# FITBANK_CLIENT_ID=
# FITBANK_CLIENT_SECRET=
# FITBANK_WEBHOOK_SECRET=
# FITBANK_PIX_KEY=

# ── KYC / Verificação Financeira (Fase 25) ───────────────────────
KYC_PROVIDER=simulated
KYC_ENABLE_REAL_CALLS=false
# Simulação bloqueada em production automaticamente (não precisa declarar)
# FUTURE_KYC_PROVIDER_API_KEY=

# ── Blockchain — Prova de Integridade (Fase 26) ──────────────────
# Provider: simulated (padrão) | testnet
BLOCKCHAIN_PROVIDER=simulated

# Rede testnet: polygon_amoy | ethereum_sepolia
BLOCKCHAIN_NETWORK=polygon_amoy

# Habilitar chamadas reais ao testnet. NUNCA true sem instrução explícita.
BLOCKCHAIN_ENABLE_REAL_CALLS=false

# Confirmações de bloco aguardadas (apenas com provider testnet real)
BLOCKCHAIN_CONFIRMATIONS=1

# Configurações de testnet — preencher SOMENTE se BLOCKCHAIN_PROVIDER=testnet
# NUNCA commitar valores reais
# BLOCKCHAIN_RPC_URL=
# BLOCKCHAIN_PRIVATE_KEY=     ← NUNCA commitar
# BLOCKCHAIN_CONTRACT_ADDRESS=

# ═══════════════════════════════════════════════════════════════════
# SEÇÃO STAGING — preencher apenas para ambiente de staging
# Copie como .env.staging e nunca commite com valores reais
# Ver docs/deploy-staging.md para instruções completas
# ═══════════════════════════════════════════════════════════════════

# POSTGRES_USER=selo_staging
# POSTGRES_PASSWORD=<senha-forte-gerada-externamente>
# POSTGRES_DB=selodb_staging
# POSTGRES_PORT=5432
# DATABASE_URL="postgresql://selo_staging:<senha>@<host-staging>:5432/selodb_staging?schema=public"

# PORT=3000
# NODE_ENV=staging
# LOG_LEVEL=info

# JWT_SECRET=<secret-forte-64-chars-minimo-gerado-externamente>
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_SECRET=<outro-secret-forte-diferente-do-jwt-secret>
# JWT_REFRESH_EXPIRES_IN=7d
# ADMIN_JWT_SECRET=<terceiro-secret-forte-diferente-dos-anteriores>
# ADMIN_JWT_EXPIRES_IN=1d

# CORS_ORIGINS=https://admin.staging.selo.app,https://staging.expo.dev
# RATE_LIMIT_TTL=60000
# RATE_LIMIT_MAX=100

# APP_PUBLIC_URL=https://admin.staging.selo.app
# API_PUBLIC_URL=https://api.staging.selo.app/api/v1

# PAYMENT_PROVIDER=simulated
# FITBANK_ENV=sandbox
# FITBANK_ENABLE_REAL_CALLS=false

# KYC_PROVIDER=simulated
# KYC_ENABLE_REAL_CALLS=false

# BLOCKCHAIN_PROVIDER=simulated
# BLOCKCHAIN_ENABLE_REAL_CALLS=false
# BLOCKCHAIN_NETWORK=polygon_amoy
