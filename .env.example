# ============================
# Selo — Variáveis de Ambiente (raiz)
# ============================
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env.
# Ver docs/environments.md para detalhes por ambiente.

# ── Banco de dados PostgreSQL (Docker Compose) ────────────────────
POSTGRES_USER=selo
POSTGRES_PASSWORD=selopassword
POSTGRES_DB=selodb
POSTGRES_PORT=5434

# String de conexão Prisma (gerada a partir das variáveis acima)
DATABASE_URL="postgresql://selo:selopassword@localhost:5434/selodb?schema=public"

# ── App ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=log

# ── JWT — access token (curta duração) ───────────────────────────
JWT_SECRET=troque-por-uma-string-secreta-de-pelo-menos-64-chars
JWT_EXPIRES_IN=15m

# ── JWT — refresh token (longa duração, secret diferente) ────────
JWT_REFRESH_SECRET=troque-por-outro-secret-diferente-do-jwt-secret-64-chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Admin JWT (secret separado do JWT de usuário) ─────────────────
ADMIN_JWT_SECRET=troque-este-segredo-admin-de-pelo-menos-64-chars-aqui
ADMIN_JWT_EXPIRES_IN=1d

# ── CORS (separar múltiplas origens por vírgula) ──────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# ── Rate limit ────────────────────────────────────────────────────
# TTL em milissegundos (60000 = 60s), MAX = requisições por janela
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# ── URLs públicas ─────────────────────────────────────────────────
APP_PUBLIC_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:3000/api/v1

# ── Pagamento — provider ──────────────────────────────────────────
# simulated         → comportamento simulado local (padrão)
# fitbank_sandbox   → sandbox Fitbank sem chamada real
PAYMENT_PROVIDER=simulated

# ── Fitbank Sandbox (Fase 24 — não usar valores reais) ────────────
FITBANK_ENV=sandbox
FITBANK_ENABLE_REAL_CALLS=false
# FITBANK_API_BASE_URL=https://sandbox.fitbank.com.br
# FITBANK_CLIENT_ID=
# FITBANK_CLIENT_SECRET=
# FITBANK_WEBHOOK_SECRET=
# FITBANK_PIX_KEY=

# ── Blockchain (Fase 26+) ─────────────────────────────────────────
# FUTURE_BLOCKCHAIN_NETWORK=ethereum-testnet
# FUTURE_BLOCKCHAIN_RPC_URL=
# FUTURE_BLOCKCHAIN_PRIVATE_KEY=
# FUTURE_BLOCKCHAIN_CONTRACT_ADDRESS=
